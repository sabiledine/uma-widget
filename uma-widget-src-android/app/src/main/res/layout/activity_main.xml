<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/app_background_img"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/main_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:background="@drawable/background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FF7DB4"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="0dp"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYER CONFIGURATION"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="0dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Username"
                        android:textColor="#1A2F4B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/input_pseudo"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/input_uma_shape"
                        android:hint="Trainer Name..."
                        android:textColorHint="#AAB4C1"
                        android:textColor="#1A2F4B"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="textNoSuggestions"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PIN Code"
                        android:textColor="#1A2F4B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/input_pin"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/input_uma_shape"
                        android:hint="4 digits"
                        android:textColorHint="#AAB4C1"
                        android:textColor="#1A2F4B"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="numberPassword"
                        android:maxLength="4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#76D743"
                        android:padding="10dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/karats_logo"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CUSTOMISATION"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <EditText
                            android:id="@+id/input_bg_url"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/input_uma_shape"
                            android:hint="Image URL link..."
                            android:textColorHint="#AAB4C1"
                            android:textColor="#1A2F4B"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:inputType="textUri"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vertical alignment"
                            android:textColor="#1A2F4B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <RadioGroup
                            android:id="@+id/radio_group_align"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:textColor="#1A2F4B"
                            android:layout_marginBottom="16dp">

                            <RadioButton
                                android:id="@+id/radio_top"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Top"
                                android:textColor="#1A2F4B"
                                android:textSize="12sp"/>
                            <RadioButton
                                android:id="@+id/radio_center"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Center"
                                android:textSize="12sp"
                                android:textColor="#1A2F4B"
                                android:checked="true"/>
                            <RadioButton
                                android:id="@+id/radio_bottom"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Bottom"
                                android:textColor="#1A2F4B"
                                android:textSize="12sp"/>
                        </RadioGroup>

                        <Switch
                            android:id="@+id/switch_text_color"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:text="Black text color"
                            android:textColor="#1A2F4B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"
                            android:thumbTint="#FF7DB4"
                            android:trackTint="#BBFF7DB4"/>

                        <Switch
                            android:id="@+id/switch_app_bg"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:text="Use as app background"
                            android:textColor="#1A2F4B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:thumbTint="#76D743"
                            android:trackTint="#BB76D743"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/btn_uma_perfect"
                android:elevation="2dp"
                android:gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingBottom="15dp"
                android:singleLine="true"
                android:stateListAnimator="@null"
                android:text="Save &amp; Sync"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <LinearLayout
                android:id="@+id/container_support"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/rounded_support_background"
                android:clickable="true"
                android:contentDescription="Support me!"
                android:elevation="4dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/btn_reseau_social"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_straw_page" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:text="support me!"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>